  <button class="scroll-top" id="scrollTop" aria-label="Back to Top">
    <i data-lucide="chevron-up"></i>
  </button>

  <script src="https://unpkg.com/lucide@latest"></script>
  <script src="./assets/js/directory.js"></script>
