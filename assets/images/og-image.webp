<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found | Dubai Coffee Guide</title>
  <meta name="description" content="Your ultimate guide to the best coffee shops, specialty roasters, and cafes across Dubai.">
